{
  "swagger": "2.0",
  "info": {
    "title": "SAC – API Gestion Présences NFC",
    "description": "API REST pour la gestion des présences via NFC (élèves, professeurs, administration)",
    "version": "2.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/api",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],

  "securityDefinitions": {
    "oauth2": {
      "type": "oauth2",
      "flow": "implicit",
      "authorizationUrl": "/api/o365/login",
      "scopes": {
        "user": "Utilisateur authentifié"
      }
    }
  },

  "paths": {
    "/system/test": {
      "get": {
        "summary": "Healthcheck",
        "responses": {
          "200": {
            "description": "API OK",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        },
        "tags": ["System"]
      }
    },

    "/user/me": {
      "get": {
        "summary": "Profil utilisateur connecté",
        "security": [{ "oauth2": ["user"] }],
        "responses": {
          "200": {
            "schema": { "$ref": "#/definitions/User" }
          }
        },
        "tags": ["User"]
      }
    },

    "/sessions/today": {
      "get": {
        "summary": "Sessions du jour pour l'utilisateur",
        "security": [{ "oauth2": ["user"] }],
        "responses": {
          "200": {
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/CourseSession" }
            }
          }
        },
        "tags": ["Sessions"]
      }
    },

    "/sessions/{sessionId}": {
      "get": {
        "summary": "Détail d'une session",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "security": [{ "oauth2": ["user"] }],
        "responses": {
          "200": {
            "schema": { "$ref": "#/definitions/CourseSession" }
          }
        },
        "tags": ["Sessions"]
      }
    },

    "/nfc/scan": {
      "post": {
        "summary": "Scanner NFC (élève ou prof)",
        "description": "Valide la présence automatiquement selon le cours importé actuellement en cours dans la salle NFC. L'enseignant affecté au cours doit valider sa présence avant les élèves. Les élèves et enseignants doivent fournir une signature manuscrite en base64.",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/NfcScanRequest" }
          }
        ],
        "responses": {
          "200": {
            "schema": { "$ref": "#/definitions/ScanResponse" }
          },
          "400": { "description": "Requête invalide" },
          "401": { "description": "Utilisateur non authentifié" },
          "403": { "description": "Refusé" },
          "404": { "description": "Salle inconnue" }
        },
        "tags": ["NFC"]
      }
    },

    "/nfc/scan/prepare": {
      "post": {
        "summary": "Préparer un scan NFC",
        "description": "Vérifie le cours, le rôle, l'ordre de validation et si la présence est déjà enregistrée avant d'afficher la signature côté frontend.",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/NfcPrepareRequest" }
          }
        ],
        "responses": {
          "200": {
            "schema": { "$ref": "#/definitions/ScanResponse" }
          },
          "400": { "description": "Requête invalide" },
          "401": { "description": "Utilisateur non authentifié" },
          "403": { "description": "Refusé ou présence déjà enregistrée" },
          "404": { "description": "Salle inconnue" }
        },
        "tags": ["NFC"]
      }
    },

    "/nfc/scan/finalize/prepare": {
      "post": {
        "summary": "Préparer la validation finale d'un appel",
        "description": "Route enseignant appelée après un second scan NFC. Retourne le résumé de l'appel à confirmer avant envoi EcoleDirecte.",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/NfcPrepareRequest" }
          }
        ],
        "responses": {
          "200": { "schema": { "$ref": "#/definitions/FinalizePrepareResponse" } },
          "403": { "description": "Refusé" },
          "404": { "description": "Salle ou session introuvable" }
        },
        "tags": ["NFC"]
      }
    },

    "/nfc/scan/finalize": {
      "post": {
        "summary": "Valider définitivement l'appel",
        "description": "Envoie les absences à EcoleDirecte avec l'horaire du cours, puis génère le PDF d'émargement de la session.",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["sessionId"],
              "properties": {
                "sessionId": { "type": "integer" }
              }
            }
          }
        ],
        "responses": {
          "200": { "schema": { "$ref": "#/definitions/FinalizeResponse" } },
          "400": { "description": "Requête invalide" },
          "403": { "description": "Refusé" },
          "404": { "description": "Session introuvable" }
        },
        "tags": ["NFC"]
      }
    },

    "/attendance/session/{sessionId}": {
      "get": {
        "summary": "Liste des présences (prof)",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/AttendanceRecord" }
            }
          }
        },
        "tags": ["Attendance"]
      }
    },

    "/attendance/session/{sessionId}/validate": {
      "post": {
        "summary": "Validation manuelle des présences (prof)",
        "description": "Permet au prof de corriger les absences",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/AttendanceUpdate" }
            }
          }
        ],
        "responses": {
          "200": {
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        },
        "tags": ["Attendance"]
      }
    },

    "/attendance/me": {
      "get": {
        "summary": "Historique personnel",
        "security": [{ "oauth2": ["user"] }],
        "responses": {
          "200": {
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/AttendanceRecord" }
            }
          }
        },
        "tags": ["Attendance"]
      }
    },

    "/classes/me": {
      "get": {
        "summary": "Classe de l'élève ou classes du prof",
        "security": [{ "oauth2": ["user"] }],
        "responses": {
          "200": {
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/Class" }
            }
          }
        },
        "tags": ["Classes"]
      }
    },

    "/admin/stats": {
      "get": {
        "summary": "Statistiques globales",
        "security": [{ "oauth2": ["user"] }],
        "responses": {
          "200": {
            "schema": { "$ref": "#/definitions/Stats" }
          }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/users": {
      "get": {
        "summary": "Lister les utilisateurs",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "role",
            "in": "query",
            "type": "string",
            "enum": ["student", "teacher", "staff"]
          }
        ],
        "responses": {
          "200": {
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/User" }
            }
          }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/users/{userId}/role": {
      "patch": {
        "summary": "Modifier le rôle d’un utilisateur",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "schema": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string",
                  "enum": ["student", "teacher", "staff"]
                }
              }
            }
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/MessageResponse" }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/sessions": {
      "post": {
        "summary": "Créer une session de cours",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/CourseSession" }
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/CourseSession" }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/sessions/{sessionId}": {
      "patch": {
        "summary": "Modifier une session (heure, salle, prof)",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/CourseSession" }
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/CourseSession" }
        },
        "tags": ["Admin"]
      },

      "delete": {
        "summary": "Supprimer une session",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/MessageResponse" }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/attendance/override": {
      "post": {
        "summary": "Forcer une présence (correction manuelle)",
        "description": "Corrige une erreur de scan ou ajoute une présence manquante",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": {
              "type": "object",
              "required": ["sessionId", "studentId", "status"],
              "properties": {
                "sessionId": { "type": "integer" },
                "studentId": { "type": "integer" },
                "status": {
                  "type": "string",
                  "enum": ["present", "late", "absent", "excused"]
                },
                "reason": { "type": "string" }
              }
            }
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/MessageResponse" }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/attendance/reset/{sessionId}": {
      "post": {
        "summary": "Réinitialiser toutes les présences d'une session",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/MessageResponse" }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/nfc/logs": {
      "get": {
        "summary": "Logs des scans NFC",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "type": "integer"
          },
          {
            "name": "from",
            "in": "query",
            "type": "string",
            "format": "date-time"
          }
        ],
        "responses": {
          "200": {
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/NfcScan" }
            }
          }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/nfc/reassign": {
      "post": {
        "summary": "Associer un badge NFC à un utilisateur",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": {
              "type": "object",
              "properties": {
                "nfcUid": { "type": "string" },
                "userId": { "type": "integer" }
              }
            }
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/MessageResponse" }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/classes/{classId}/students": {
      "post": {
        "summary": "Ajouter un élève à une classe",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "classId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "schema": {
              "type": "object",
              "properties": {
                "userId": { "type": "integer" }
              }
            }
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/MessageResponse" }
        },
        "tags": ["Admin"]
      }
    },

    "/admin/classes/{classId}/students/{userId}": {
      "delete": {
        "summary": "Retirer un élève d’une classe",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "classId",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": { "$ref": "#/definitions/MessageResponse" }
        },
        "tags": ["Admin"]
      }
    }
  },

  "definitions": {
    "MessageResponse": {
      "type": "object",
      "properties": {
        "message": { "type": "string" }
      }
    },

    "User": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["student", "teacher", "staff"]
        }
      }
    },

    "Class": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "code": { "type": "string" },
        "name": { "type": "string" }
      }
    },

    "CourseSession": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "classId": { "type": "integer" },
        "roomId": { "type": "integer" },
        "teacherId": { "type": "integer" },
        "startTime": {
          "type": "string",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "AttendanceRecord": {
      "type": "object",
      "properties": {
        "sessionId": { "type": "integer" },
        "userId": { "type": "integer" },
        "status": {
          "type": "string",
          "enum": ["present", "absent"]
        },
        "signature": { "type": "string" },
        "scannedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "AttendanceUpdate": {
      "type": "object",
      "properties": {
        "userId": { "type": "integer" },
        "status": {
          "type": "string",
          "enum": ["present", "absent"]
        }
      }
    },

    "/attendance/pdf/day": {
      "get": {
        "summary": "PDF journalier d'une classe",
        "description": "Génère un seul PDF contenant toutes les feuilles d'émargement des sessions d'une classe pour une journée.",
        "security": [{ "oauth2": ["user"] }],
        "parameters": [
          {
            "name": "classId",
            "in": "query",
            "required": true,
            "type": "integer"
          },
          {
            "name": "date",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date"
          }
        ],
        "responses": {
          "200": { "description": "PDF" },
          "404": { "description": "Aucune session" }
        },
        "tags": ["Attendance"]
      }
    },

    "NfcScan": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "nfcUid": { "type": "string" },
        "roomId": { "type": "integer" },
        "userId": { "type": "integer" },
        "sessionId": { "type": "integer" },
        "eventType": {
          "type": "string",
          "enum": ["room_scan", "system_event"]
        },
        "comment": { "type": "string" },
        "scannedAt": {
          "type": "string",
          "format": "date-time"
        },
        "ipAddress": { "type": "string" },
        "UserAgent": { "type": "string" },
        "deviceFingerprint": {
          "type": "string",
          "description": "SHA-256 du fingerprint navigateur envoye via l'en-tete x-device-fingerprint."
        }
      }
    },

    "NfcScanRequest": {
      "type": "object",
      "required": ["nfcUid"],
      "properties": {
        "nfcUid": {
          "type": "string",
          "description": "UID NFC de la salle, par exemple ROOM_123"
        },
        "signature": {
          "type": "string",
          "description": "Image de signature manuscrite au format data URL base64 PNG/JPEG. Obligatoire pour les élèves et enseignants."
        }
      }
    },

    "NfcPrepareRequest": {
      "type": "object",
      "required": ["nfcUid"],
      "properties": {
        "nfcUid": {
          "type": "string",
          "description": "UID NFC de la salle, par exemple ROOM_123"
        }
      }
    },

    "ScanResponse": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "sessionId": { "type": "integer" },
        "message": { "type": "string" },
        "room": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["student", "teacher", "staff", "admin"]
        }
      }
    },

    "FinalizePrepareResponse": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "message": { "type": "string" },
        "sessionId": { "type": "integer" },
        "className": { "type": "string" },
        "courseLabel": { "type": "string" },
        "horaire": { "type": "string" },
        "presentCount": { "type": "integer" },
        "absentCount": { "type": "integer" },
        "totalStudents": { "type": "integer" }
      }
    },

    "FinalizeResponse": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "message": { "type": "string" },
        "sessionId": { "type": "integer" },
        "pdf": {
          "type": "object",
          "properties": {
            "filename": { "type": "string" },
            "contentType": { "type": "string" },
            "contentBase64": { "type": "string" }
          }
        }
      }
    },

    "Stats": {
      "type": "object",
      "properties": {
        "totalStudents": { "type": "integer" },
        "present": { "type": "integer" },
        "absent": { "type": "integer" },
        "late": { "type": "integer" }
      }
    }
  },

  "tags": [
    { "name": "System" },
    { "name": "User" },
    { "name": "Sessions" },
    { "name": "NFC" },
    { "name": "Attendance" },
    { "name": "Classes" },
    { "name": "Admin" }
  ]
}
