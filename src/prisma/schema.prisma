generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  student
  teacher
  staff
  admin
}

enum AttendanceStatus {
  present
  absent
}

enum SessionStatus {
  scheduled
  ongoing
  completed
  cancelled
}

model User {
  id         Int      @id @default(autoincrement())
  externalId String?  @unique
  role       UserRole
  email      String?  @unique
  firstName  String?
  lastName   String?
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student Student?
  teacher Teacher? 
  staff Staff?

  attendance AttendanceRecord[]
  nfcScans   NfcScan[]
}

model Student {
  id         Int     @id @default(autoincrement())
  userId     Int?    @unique
  externalId String? @unique
  classId    Int?
  photo      String?

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  class Class? @relation(fields: [classId], references: [id])
}

model Teacher {
  id         Int     @id @default(autoincrement())
  userId     Int?    @unique
  externalId String? @unique

  firstName String?
  lastName  String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  sessions CourseSession[]
}

model Staff {
  id         Int     @id @default(autoincrement())
  userId     Int?    @unique
  externalId String? @unique

  user User? @relation(fields: [userId], references: [id])
}

model Room {
  id         Int     @id @default(autoincrement())
  code       String  @unique
  name       String?
  nfcUid     String  @unique
  reservable Boolean @default(true)

  sessions CourseSession[]
  scans    NfcScan[] // 🔥 link to scans
}

model Class {
  id         Int      @id @default(autoincrement())
  externalId Int?     @unique
  code       String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  students Student[]
  sessions CourseSession[]

  @@unique([code])
}

model CourseSession {
  id        Int      @id @default(autoincrement())
  classId   Int
  roomId    Int
  teacherId Int
  color     String?
  matiere   String?
  codeMatiere String? 
  label     String?
  startTime DateTime
  endTime   DateTime
  status    SessionStatus @default(scheduled)
  externalId String?       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class   Class   @relation(fields: [classId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  attendance AttendanceRecord[]

  @@index([teacherId, startTime, endTime])
  @@index([roomId, startTime, endTime])
}

model AttendanceRecord {
  sessionId Int
  studentId Int
  status    AttendanceStatus
  scannedAt DateTime?

  createdAt DateTime @default(now())   // ✅ audit (fix #7)
  updatedAt DateTime @updatedAt        // ✅ audit (fix #7)

  session CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([sessionId, studentId])
}

model NfcScan {
  id        Int      @id @default(autoincrement())
  nfcUid    String
  roomId    Int?     // ✅ added relation (fix #4)
  userId    Int?
  scannedAt DateTime @default(now())
  ipAddress String?
  UserAgent String?
  DeviceId  String?

  room Room? @relation(fields: [roomId], references: [id], onDelete: SetNull) // ✅ link
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model BrowserSession {
  id        String   @id @default(uuid())
  sid       String   @unique
  data      Json
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}