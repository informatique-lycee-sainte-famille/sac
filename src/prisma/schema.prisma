// ./prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  student
  teacher
  staff
  admin
}

enum AttendanceStatus {
  present
  absent
}

enum SessionStatus {
  scheduled
  ongoing
  completed
  cancelled
}

enum NfcScanEventType {
  room_scan
  system_event
}

model User {
  id         Int      @id @default(autoincrement())

  o365Id     String?  @unique   // Azure / Microsoft ID
  edId       String?  @unique   // EcoleDirecte ID

  role       UserRole

  o365Email  String?  @unique
  edEmail    String?

  firstName  String?
  lastName   String?

  o365AvatarB64 String?
  edPhotoUrl    String?
  edPhotoB64    String?

  classId    Int?

  metadata   Json?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  class Class? @relation(fields: [classId], references: [id])

  teachingSessions CourseSession[] @relation("TeacherSessions")
  finalizedSessions CourseSessionFinalization[] @relation("CourseSessionFinalizations")

  attendance AttendanceRecord[]
  nfcScans   NfcScan[]
  businessLogs BusinessLog[]
}

model Room {
  id         Int     @id @default(autoincrement())
  code       String  @unique
  name       String?
  nfcUid     String  @unique
  reservable Boolean @default(true)

  sessions CourseSession[]
  scans    NfcScan[]
}

model Class {
  id         Int      @id @default(autoincrement())
  edId       Int?     @unique
  code       String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users    User[]          // 🔥 replaces Student[]
  sessions CourseSession[]

  @@unique([code])
}

model CourseSession {
  id           Int      @id @default(autoincrement())
  classId      Int
  roomId       Int
  teacherId    Int      // now points to User

  color        String?
  matiere      String?
  codeMatiere  String?
  label        String?

  startTime    DateTime
  endTime      DateTime

  status       SessionStatus @default(scheduled)
  edId         String?       @unique

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  class   Class @relation(fields: [classId], references: [id])
  room    Room  @relation(fields: [roomId], references: [id])
  teacher User  @relation("TeacherSessions", fields: [teacherId], references: [id])

  attendance AttendanceRecord[]
  finalization CourseSessionFinalization?

  @@index([teacherId, startTime, endTime])
  @@index([roomId, startTime, endTime])
}

model CourseSessionFinalization {
  id            Int      @id @default(autoincrement())
  sessionId     Int      @unique
  sentByUserId  Int
  sentToEdAt    DateTime @default(now())
  pdfFilename   String?
  edResponse    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sentBy  User          @relation("CourseSessionFinalizations", fields: [sentByUserId], references: [id], onDelete: Restrict)
}

model AttendanceRecord {
  sessionId Int
  userId    Int

  status    AttendanceStatus
  signature String?
  scannedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

model NfcScan {
  id        Int      @id @default(autoincrement())
  nfcUid    String
  roomId    Int?
  userId    Int?
  sessionId Int?
  eventType NfcScanEventType @default(room_scan)
  comment   String?

  scannedAt DateTime @default(now())
  ipAddress String?
  UserAgent String?
  deviceFingerprint String?

  room Room? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model BrowserSession {
  id        String   @id @default(uuid())
  sid       String   @unique
  data      Json
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessLog {
  id         Int      @id @default(autoincrement())
  event      String
  message    String
  level      String   @default("INFO")
  userId     Int?
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([event])
  @@index([userId, createdAt])
}
