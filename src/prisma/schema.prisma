generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  student
  teacher
  staff
  admin
}

enum AttendanceStatus {
  present
  absent
}

enum SessionStatus {
  scheduled
  ongoing
  completed
  cancelled
}

model User {
  id         Int      @id @default(autoincrement())

  // 🔐 IDs
  o365Id     String?  @unique   // Azure / Microsoft ID
  edId       String?  @unique   // EcoleDirecte ID

  role       UserRole

  // 📧 Emails
  o365Email  String?  @unique
  edEmail    String?

  // 👤 Identity
  firstName  String?
  lastName   String?

  // 🖼 Avatars
  o365AvatarB64 String?
  edPhotoUrl    String?

  // 🎓 Student-specific
  classId    Int?

  // 🧠 Optional flexible field (future-proof)
  metadata   Json?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 🔗 Relations
  class Class? @relation(fields: [classId], references: [id])

  teachingSessions CourseSession[] @relation("TeacherSessions")

  attendance AttendanceRecord[]
  nfcScans   NfcScan[]
}

model Room {
  id         Int     @id @default(autoincrement())
  code       String  @unique
  name       String?
  nfcUid     String  @unique
  reservable Boolean @default(true)

  sessions CourseSession[]
  scans    NfcScan[]
}

model Class {
  id         Int      @id @default(autoincrement())
  externalId Int?     @unique
  code       String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users    User[]          // 🔥 replaces Student[]
  sessions CourseSession[]

  @@unique([code])
}

model CourseSession {
  id           Int      @id @default(autoincrement())
  classId      Int
  roomId       Int
  teacherId    Int      // now points to User

  color        String?
  matiere      String?
  codeMatiere  String?
  label        String?

  startTime    DateTime
  endTime      DateTime

  status       SessionStatus @default(scheduled)
  externalId   String?       @unique

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  class   Class @relation(fields: [classId], references: [id])
  room    Room  @relation(fields: [roomId], references: [id])
  teacher User  @relation("TeacherSessions", fields: [teacherId], references: [id])

  attendance AttendanceRecord[]

  @@index([teacherId, startTime, endTime])
  @@index([roomId, startTime, endTime])
}

model AttendanceRecord {
  sessionId Int
  userId    Int

  status    AttendanceStatus
  signature String?
  scannedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

model NfcScan {
  id        Int      @id @default(autoincrement())
  nfcUid    String
  roomId    Int?
  userId    Int?

  scannedAt DateTime @default(now())
  ipAddress String?
  UserAgent String?
  DeviceId  String?

  room Room? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model BrowserSession {
  id        String   @id @default(uuid())
  sid       String   @unique
  data      Json
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}